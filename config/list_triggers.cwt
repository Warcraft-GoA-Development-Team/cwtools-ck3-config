### Iterate through the title itself, all de jure vassals, and below. The continue trigger specifies whether to recursively iterate through the vassal's vassal
### This is unrelated to the limit; if the limit is met it is added to the list, but its vassals will get checked even if the limit isn't met as long as the 'continue' trigger is
### ..._de_jure_vassal_and_below = { continue = { conditions } }
### any_in_de_jure_hierarchy = { <count=num/all> / <percent=fixed_point> <triggers> }
## scope = landed_title
## push_scope = landed_title
alias[trigger:any_in_de_jure_hierarchy] = {
    ## cardinality = 0..1
    continue = {
        alias_name[trigger] = alias_match_left[trigger]
    }
    ## cardinality = 0..1
    percent = float[0.0..1.0]
    ## cardinality = 0..1
    percent = alias_keys_field[script_value]
    ## cardinality = 0..1
    count = alias_keys_field[int_value]
    ## cardinality = 0..1
    count = single_alias_right[score_formula]
    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = all
    alias_name[trigger] = alias_match_left[trigger]
    ## cardinality = 0..1
    filter = {
        tier = enum[title_tier]
    }
}

### Iterate through all investors of target candidate within the scoped title. Optionally specify a value to filter by investment amount
## scope = landed_title
## push_scope = character
alias[trigger:any_succession_appointment_investors] = {
    ## cardinality = 0..1
    continue = {
        alias_name[trigger] = alias_match_left[trigger]
    }
    ## cardinality = 0..1
    percent = float[0.0..1.0]
    ## cardinality = 0..1
    percent = alias_keys_field[script_value]
    ## cardinality = 0..1
    count = alias_keys_field[int_value]
    ## cardinality = 0..1
    count = single_alias_right[score_formula]
    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = all
    alias_name[trigger] = alias_match_left[trigger]
    ## cardinality = 0..1
    candidate = scope[character]
    ## cardinality = 0..1
    value == int_value_field
    ## cardinality = 0..1
    value == alias_keys_field[int_value]
    ## cardinality = 0..1
    value == single_alias_right[score_formula]
}

### Iterate through all held landed titles. Optionally specify a tier filter
### any/every/ordered/random_held_title = { title_tier >= county }
## scope = character
## push_scope = landed_title
alias[trigger:any_held_title] = {
    ## cardinality = 0..1
    continue = {
        alias_name[trigger] = alias_match_left[trigger]
    }
    ## cardinality = 0..1
    title_tier == enum[title_tier]
    ## cardinality = 0..1
    percent = float[0.0..1.0]
    ## cardinality = 0..1
    percent = alias_keys_field[script_value]
    ## cardinality = 0..1
    count = alias_keys_field[int_value]
    ## cardinality = 0..1
    count = single_alias_right[score_formula]
    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = all
    alias_name[trigger] = alias_match_left[trigger]
}

### Iterate through all active Accolades of a given liege character's Acclaimed Knights
### Optionally specify an accolade parameter filter
### any_active_accolade = { accolade_parameter = accolade_organize_army_bonus }
### any_active_accolade = { <count=num/all> / <percent=fixed_point> <triggers> }
## scope = character
## push_scope = accolade
alias[trigger:any_active_accolade] = {
    ## cardinality = 0..1
    continue = {
        alias_name[trigger] = alias_match_left[trigger]
    }
    ## cardinality = 0..1
    accolade_parameter == enum[accolade_parameter]
    ## cardinality = 0..1
    percent = float[0.0..1.0]
    ## cardinality = 0..1
    percent = alias_keys_field[script_value]
    ## cardinality = 0..1
    count = alias_keys_field[int_value]
    ## cardinality = 0..1
    count = single_alias_right[score_formula]
    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = all
    alias_name[trigger] = alias_match_left[trigger]
}

