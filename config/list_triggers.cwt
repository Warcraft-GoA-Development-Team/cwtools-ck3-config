    ## cardinality = 0..1
    percent = float[0.0..1.0]
    ## cardinality = 0..1
    percent = alias_keys_field[script_value]
    ## cardinality = 0..1
    count = alias_keys_field[int_value]
    ## cardinality = 0..1
    count = single_alias_right[score_formula]
    ## cardinality = 0..1
    count = int_value_field
    ## cardinality = 0..1
    count = all
    alias_name[trigger] = alias_match_left[trigger]
}

